<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100" width="100" height="100">
  <!-- Background circle -->
  <circle cx="50" cy="50" r="48" fill="#1a1a1a" stroke="#e74c3c" stroke-width="2"/>
  
  <!-- Wrench icon -->
  <g transform="translate(50, 50)">
    <!-- Wrench handle -->
    <path d="M -15 -5 L 5 -5 L 8 -2 L 8 2 L 5 5 L -15 5 Z" fill="none" stroke="#e74c3c" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
    
    <!-- Wrench head -->
    <circle cx="15" cy="0" r="8" fill="none" stroke="#e74c3c" stroke-width="2.5"/>
    <circle cx="15" cy="0" r="4" fill="#e74c3c"/>
  </g>
</svg>
